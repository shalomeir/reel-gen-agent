# reel-gen-agent 환경변수. 값은 비우고 각자 키를 주입해 실행한다.

# --- 분석/이미지 (필수) ---
# 발급처: Google AI Studio (https://aistudio.google.com/apikey)
# 용도: 영상 비정형 분석(Gemini 멀티모달) + 에셋/스토리보드 이미지 생성(나노 바나나)
GEMINI_API_KEY=

# 분석 모델(선택, 기본 gemini-2.5-flash)
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
# 이미지 생성 모델(선택, 기본 gemini-3.1-flash-image)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# --- 영상/음악 생성 (generate 단계에서 사용) ---
# 용도: 스토리보드 스틸 -> 영상(image-to-video)
VEO_MODEL=veo-3.1-fast-generate-001
# 용도: 배경음악 생성
LYRIA_MODEL=lyria-3-pro-preview

# --- 보이스오버 (옵션 데모에서만) ---
# 발급처: ElevenLabs (https://elevenlabs.io)
ELEVENLABS_API_KEY=
