# reel-gen-agent environment template.
# Copy this file to .env and fill in your own keys. Do not commit .env.

# =============================================================================
# Required now
# =============================================================================

# Required for perceptual video analysis and Gemini image generation.
# Source: Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional Claude API key for concept, storyboard, dialogue script, and tone generation.
# Source: Anthropic Console (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# =============================================================================
# Model preference order
# =============================================================================

# If these priority variables are blank, the app uses the first model shown in
# the related section below.
#
# Comma-separated priority lists are for future backend selection and should use
# provider:model-id entries when multiple providers can serve the same stage.
TEXT_MODEL_PRIORITY=gemini:gemini-3.1-pro-preview,claude:claude-opus-4-8
# Image provider selection when multiple image providers are configured.
# Valid values: gemini, imagen, fal. Blank means gemini.
IMAGE_PROVIDER=
IMAGE_MODEL_PRIORITY=gemini:gemini-3.1-flash-image-preview,gemini:gemini-3-pro-image-preview,imagen:imagen-4.0-fast-generate-001,imagen:imagen-4.0-generate-001,fal:fal-ai/flux-2-pro,fal:fal-ai/flux-2-max,fal:fal-ai/flux-2-flex
VIDEO_MODEL_PRIORITY=vertex-veo:veo-3.1-lite-generate-001,vertex-veo:veo-3.1-fast-generate-001,gemini-veo:veo-3.1-lite-generate-preview,gemini-veo:veo-3.1-fast-generate-preview,fal:fal-ai/kling-video/o3/standard/reference-to-video,fal:fal-ai/kling-video/o3/standard/image-to-video,fal:bytedance/seedance-2.0/fast/image-to-video
TTS_MODEL_PRIORITY=gemini:gemini-3.1-flash-tts-preview,gemini:gemini-2.5-flash-preview-tts,elevenlabs:eleven_multilingual_v2
# SFX lane order:
# 1. elevenlabs: generated one-shots, transition whooshes, foley, ambience, and
#    short loops when ELEVENLABS_API_KEY is configured.
# 2. local: user-provided SFX library.
# 3. silent: no SFX fallback.
SFX_PROVIDER_PRIORITY=elevenlabs:eleven_text_to_sound_v2,local:provided,silent:none
# Music lane order:
# 1. lyria: generated music bed when LYRIA_MODEL is configured.
# 2. local: user-provided local music bed.
# 3. silent: no music fallback.
MUSIC_MODEL_PRIORITY=lyria:lyria-3-pro-preview,local:provided,silent:none

# =============================================================================
# Gemini analysis and image generation
# =============================================================================

# Backend for Gemini multimodal calls (reference analysis, rubric scoring,
# conformance VLM). This selects how those calls authenticate and how the video
# reaches the model.
#   auto (default): use Vertex AI when GOOGLE_CLOUD_PROJECT and a service-account
#     credential are set (see the Google Cloud section below), so calls run on
#     Google Cloud credits. Falls back to GEMINI_API_KEY when Vertex is not ready.
#   vertex: force the Vertex AI lane; falls back to GEMINI_API_KEY only if Vertex
#     credentials are missing.
#   gemini: force the GEMINI_API_KEY lane even when Vertex credentials exist.
# Both lanes analyze the whole short clip with audio and full motion; they only
# differ in how the video is delivered (gemini uploads via the File API, vertex
# sends inline bytes). Long or large clips fall back to sampled keyframes on
# either lane. So the choice is about auth and billing, not analysis quality.
GENAI_BACKEND=auto

# Used by `reel-gen analyze`. If blank, default is gemini-2.5-flash.
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Default text model for concept, storyboard, dialogue script, and tone generation.
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview

# Optional Claude text model for storyboard, dialogue script, and tone generation.
CLAUDE_MODEL=claude-opus-4-8

# Used for asset and storyboard image generation. If blank, default is
# gemini-3.1-flash-image-preview.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# For high-fidelity asset production, consider: gemini-3-pro-image-preview

# Optional Imagen text-to-image fallback. Useful for fast, simple product stills.
IMAGEN_MODEL=imagen-4.0-fast-generate-001

# Optional fal.ai image lane. Set IMAGE_PROVIDER=fal or include fal:* entries in
# IMAGE_MODEL_PRIORITY to use FLUX.2 image providers.
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux-2-pro
# Alternatives: fal-ai/flux-2-max, fal-ai/flux-2-flex

# Gemini TTS is optional. If blank, narration is skipped unless another TTS
# provider is configured.
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# For higher-fidelity long-form voice, consider: gemini-2.5-pro-tts
# GEMINI_TTS_VOICE=Kore
# GEMINI_TTS_LANGUAGE=ko-KR
# GEMINI_TTS_AUDIO_ENCODING=MP3
# GEMINI_TTS_PROMPT=Speak in polished Korean for a short-form narration with clear pacing and a confident tone.

# =============================================================================
# Video generation
# =============================================================================

# Vertex AI stable Veo lane. This is the default video path and uses Google Cloud
# billing/credits. It requires the Google Cloud settings below.
VEO_MODEL=veo-3.1-lite-generate-001
# Example: gs://your-bucket/outputs/veo
VEO_OUTPUT_GCS_URI=

# Gemini API preview Veo lane. This uses GEMINI_API_KEY and AI Studio/Gemini API
# billing/prepay credits. Keep it as fallback.
GEMINI_VEO_MODEL=veo-3.1-lite-generate-preview
# For lower-cost A/B or calmer loop tests, consider: veo-3.1-lite-generate-preview
# GEMINI_VEO_DURATION_SECONDS=8
# GEMINI_VEO_RESOLUTION=720p

# Optional fal.ai video lane. This shares FAL_KEY with the image lane above. Set
# VIDEO_PROVIDER=fal or include fal:* entries in VIDEO_MODEL_PRIORITY to use
# Kling O3/Seedance image-to-video providers. Kling O3 reference-to-video is the
# preferred fal lane when character/product identity and reusable voice control
# matter. Create voice IDs with fal-ai/kling-video/create-voice.
FAL_VIDEO_MODEL=fal-ai/kling-video/o3/standard/reference-to-video
# Alternatives: fal-ai/kling-video/o3/pro/reference-to-video,
# fal-ai/kling-video/o3/standard/image-to-video,
# bytedance/seedance-2.0/fast/image-to-video
# FAL_VIDEO_DURATION_SECONDS=5

# =============================================================================
# Google Cloud / Vertex AI
# =============================================================================

# Used by the Vertex AI lane for both video (vertex-veo:* providers) and Gemini
# multimodal calls when GENAI_BACKEND selects Vertex. GOOGLE_CLOUD_PROJECT is the
# project ID, not the display name.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT_NUMBER=
GOOGLE_CLOUD_LOCATION=global

# Canonical Vertex auth path: an absolute path to a readable service-account JSON
# file. Do not commit that JSON.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional short-lived manual-test override. Leave blank for normal use.
GOOGLE_CLOUD_ACCESS_TOKEN=

# =============================================================================
# Music and voice
# =============================================================================

# Optional generated background music. If blank, the music lane moves to the next
# configured source in MUSIC_MODEL_PRIORITY.
LYRIA_MODEL=lyria-3-pro-preview

# Optional ElevenLabs voiceover. Keep usage within the free/monthly credit limit.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional ElevenLabs SFX generation. This is the preferred generated-SFX lane
# for promptable one-shots, transition whooshes, foley, ambience, and short loops.
ELEVENLABS_SFX_MODEL=eleven_text_to_sound_v2
ELEVENLABS_SFX_OUTPUT_FORMAT=mp3_44100_128
# 0.5-30 seconds per effect; keep default short for ad-style one-shots.
ELEVENLABS_SFX_DEFAULT_DURATION_SECONDS=2
# Hard guardrails for generated SFX calls.
ELEVENLABS_SFX_MAX_DURATION_SECONDS=2
ELEVENLABS_SFX_MAX_PER_RUN=8
# Higher values follow the prompt more literally. Range: 0-1.
ELEVENLABS_SFX_PROMPT_INFLUENCE=0.35

# =============================================================================
# Observability and product URL extraction
# =============================================================================

# Optional product URL extraction.
FIRECRAWL_API_KEY=

# Optional tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://jp.cloud.langfuse.com
